# Firebase Configuration (Vite Frontend)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Cloudflare R2 Configuration (Backend/Netlify Functions) - DO NOT prefix with VITE_
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_s3_access_key_id
R2_SECRET_ACCESS_KEY=your_s3_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name

# Cloudflare R2 Public URL (Vite Frontend)
VITE_R2_PUBLIC_URL=https://pub-your_id.r2.dev
